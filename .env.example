SITE_URL=https://BLOG_DOMAIN

# Set to true only after the public comments repo is configured in giscus.app.
PUBLIC_GISCUS_ENABLED=false
PUBLIC_GISCUS_REPO=your-github-name/blog-comments
PUBLIC_GISCUS_REPO_ID=
PUBLIC_GISCUS_CATEGORY=General
PUBLIC_GISCUS_CATEGORY_ID=
PUBLIC_GISCUS_THEME=preferred_color_scheme
