---
import PostCard from "../../../components/PostCard.astro";
import LoadMoreList from "../../../components/LoadMoreList.astro";
import { getAllTags, getEntriesByTag } from "../../../lib/content";
import { locales, localizedPath, t, tagLabel, type Locale } from "../../../lib/i18n";
import BaseLayout from "../../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const paths = [];
  for (const lang of locales) {
    const tags = await getAllTags(lang);
    for (const tag of tags) {
      paths.push({ params: { lang, tag } });
    }
  }
  return paths;
}

const lang = Astro.params.lang as Locale;
const tag = Astro.params.tag as string;
const entries = await getEntriesByTag(lang, tag);
---

<BaseLayout title={tagLabel(tag, lang)} locale={lang}>
  <header class="page-header">
    <h1>{tagLabel(tag, lang)}</h1>
  </header>
  <LoadMoreList locale={lang}>
    {
      entries.map((entry) => {
        const type = entry.collection === "blog" ? "blog" : "projects";
        const cta = entry.collection === "blog" ? t(lang, "readMore") : t(lang, "viewProject");
        return (
          <PostCard entry={entry} href={localizedPath(lang, `${type}/${entry.data.slug}`)} locale={lang} cta={cta} />
        );
      })
    }
  </LoadMoreList>
</BaseLayout>
