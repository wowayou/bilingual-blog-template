---
import { isLocale, locales, t } from "../../lib/i18n";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getSiteProfile } from "../../site.config";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const lang = isLocale(Astro.params.lang) ? Astro.params.lang : "zh";
const profile = getSiteProfile(lang);
---

<BaseLayout title={t(lang, "about")} locale={lang}>
  <article class="article-shell" data-pagefind-body>
    <header class="article-header">
      <h1>{t(lang, "about")}</h1>
      <p>{t(lang, "intro")}</p>
    </header>
    <div class="prose">
      {profile.about.map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </article>
</BaseLayout>
