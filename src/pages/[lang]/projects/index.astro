---
import PostCard from "../../../components/PostCard.astro";
import LoadMoreList from "../../../components/LoadMoreList.astro";
import { getProjects } from "../../../lib/content";
import { isLocale, locales, localizedPath, t } from "../../../lib/i18n";
import BaseLayout from "../../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const lang = isLocale(Astro.params.lang) ? Astro.params.lang : "zh";
const projects = await getProjects(lang);
---

<BaseLayout title={t(lang, "projects")} locale={lang}>
  <header class="page-header">
    <h1>{t(lang, "projects")}</h1>
    <p>{t(lang, "featuredProjects")}</p>
  </header>
  <LoadMoreList locale={lang}>
    {
      projects.length > 0 ? (
        projects.map((entry) => (
          <PostCard entry={entry} href={localizedPath(lang, `projects/${entry.data.slug}`)} locale={lang} cta={t(lang, "viewProject")} />
        ))
      ) : (
        <p class="muted">{t(lang, "noProjects")}</p>
      )
    }
  </LoadMoreList>
</BaseLayout>
