---
import { getProjects, getTranslations, type ProjectEntry } from "../../../lib/content";
import { locales, localizedPath, type Locale } from "../../../lib/i18n";
import ContentLayout from "../../../layouts/ContentLayout.astro";

export async function getStaticPaths() {
  const projects = await getProjects();
  return projects.map((entry) => ({
    params: { lang: entry.data.locale, slug: entry.data.slug },
    props: { entry }
  }));
}

const entry = Astro.props.entry as ProjectEntry;
const lang = entry.data.locale;
const translations = await getTranslations("projects", entry.data.contentId);
const alternates = Object.fromEntries(
  locales.map((locale) => {
    const translated = translations[locale] as ProjectEntry | undefined;
    return [
      locale,
      translated
        ? { href: localizedPath(locale, `projects/${translated.data.slug}`), available: true }
        : { href: "#", available: false }
    ];
  })
) as Record<Locale, { href: string; available: boolean }>;
---

<ContentLayout entry={entry} locale={lang} collection="projects" alternates={alternates} />
