---
import PostCard from "../../../components/PostCard.astro";
import LoadMoreList from "../../../components/LoadMoreList.astro";
import { getBlogPosts } from "../../../lib/content";
import { isLocale, locales, localizedPath, t } from "../../../lib/i18n";
import BaseLayout from "../../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const lang = isLocale(Astro.params.lang) ? Astro.params.lang : "zh";
const posts = await getBlogPosts(lang);
---

<BaseLayout title={t(lang, "blog")} locale={lang}>
  <header class="page-header">
    <h1>{t(lang, "blog")}</h1>
    <p>{t(lang, "siteDescription")}</p>
  </header>
  <LoadMoreList locale={lang}>
    {
      posts.length > 0 ? (
        posts.map((entry) => (
          <PostCard entry={entry} href={localizedPath(lang, `blog/${entry.data.slug}`)} locale={lang} cta={t(lang, "readMore")} />
        ))
      ) : (
        <p class="muted">{t(lang, "noPosts")}</p>
      )
    }
  </LoadMoreList>
</BaseLayout>
