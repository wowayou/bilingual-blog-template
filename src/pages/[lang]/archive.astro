---
import LoadMoreList from "../../components/LoadMoreList.astro";
import PostCard from "../../components/PostCard.astro";
import { getBlogPosts } from "../../lib/content";
import { isLocale, locales, localizedPath, t } from "../../lib/i18n";
import BaseLayout from "../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const lang = isLocale(Astro.params.lang) ? Astro.params.lang : "zh";
const posts = await getBlogPosts(lang);
---

<BaseLayout title={t(lang, "archive")} locale={lang}>
  <header class="page-header">
    <h1>{t(lang, "archive")}</h1>
    <p>{t(lang, "allPosts")}</p>
  </header>
  <LoadMoreList locale={lang} listClass="entry-grid">
    {
      posts.map((entry) => (
        <PostCard entry={entry} href={localizedPath(lang, `blog/${entry.data.slug}`)} locale={lang} cta={t(lang, "readMore")} />
      ))
    }
  </LoadMoreList>
</BaseLayout>
