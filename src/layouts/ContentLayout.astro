---
import Giscus from "../components/Giscus.astro";
import ContentFooter from "../components/ContentFooter.astro";
import TableOfContents from "../components/TableOfContents.astro";
import { render } from "astro:content";
import type { ContentEntry } from "../lib/content";
import { formatDate } from "../lib/content";
import { localizedPath, t, tagLabel, type Locale } from "../lib/i18n";
import BaseLayout from "./BaseLayout.astro";

interface Props {
  entry: ContentEntry;
  locale: Locale;
  collection: "blog" | "projects";
  alternates: Partial<Record<Locale, { href: string; available: boolean }>>;
}

const { entry, locale, collection, alternates } = Astro.props;
const { Content, headings } = await render(entry);
const tocHeadings = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
const hasToc = collection === "blog" && tocHeadings.length > 0;
const backPath = collection === "blog" ? localizedPath(locale, "blog") : localizedPath(locale, "projects");
const jsonLd = {
  "@context": "https://schema.org",
  "@type": collection === "blog" ? "BlogPosting" : "CreativeWork",
  headline: entry.data.title,
  description: entry.data.description,
  datePublished: entry.data.pubDate.toISOString(),
  dateModified: (entry.data.updatedDate ?? entry.data.pubDate).toISOString(),
  inLanguage: locale,
  url: Astro.url.toString()
};
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  locale={locale}
  alternates={alternates}
  type="article"
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <div class:list={["content-with-toc", { "has-toc": hasToc }]}>
    {hasToc && <TableOfContents headings={tocHeadings} locale={locale} />}
    <article
      class="article-shell"
      data-pagefind-body
      data-copy-code-label={t(locale, "copyCode")}
      data-copied-code-label={t(locale, "copiedCode")}
      data-copy-failed-label={t(locale, "copyFailed")}
    >
      <a class="text-link" href={backPath}>{collection === "blog" ? t(locale, "backToBlog") : t(locale, "allProjects")}</a>
      <header class="article-header">
        <div class="entry-meta">
          <time datetime={entry.data.pubDate.toISOString()}>{formatDate(entry.data.pubDate, locale)}</time>
          <span>{t(locale, entry.data.translationStatus)}</span>
        </div>
        <h1>{entry.data.title}</h1>
        <p>{entry.data.description}</p>
        {
          entry.data.tags.length > 0 && (
            <div class="tag-row">
              {entry.data.tags.map((tag) => (
                <a href={localizedPath(locale, `tags/${tag}`)}>{tagLabel(tag, locale)}</a>
              ))}
            </div>
          )
        }
      </header>
      <div class="prose">
        <Content />
      </div>
      <ContentFooter entry={entry} locale={locale} />
    </article>
  </div>
  <dialog class="image-dialog" data-image-dialog>
    <button type="button" class="image-dialog-close" data-image-dialog-close aria-label="Close">×</button>
    <img alt="" data-image-dialog-image />
  </dialog>
  <section class="comments-section" aria-labelledby="comments-title">
    <h2 id="comments-title">{t(locale, "comments")}</h2>
    <Giscus term={entry.data.contentId} locale={locale}>{t(locale, "commentsDisabled")}</Giscus>
  </section>
</BaseLayout>

<script is:inline>
  (() => {
    const dialog = document.querySelector("[data-image-dialog]");
    const dialogImage = document.querySelector("[data-image-dialog-image]");
    const closeButton = document.querySelector("[data-image-dialog-close]");
    const article = document.querySelector("[data-copy-code-label]");
    const images = [...document.querySelectorAll(".prose img")].filter(
      (image) => image instanceof HTMLImageElement && !image.closest("a")
    );
    const codeBlocks = [...document.querySelectorAll(".prose pre")].filter(
      (pre) => pre instanceof HTMLPreElement && !pre.dataset.copyEnhanced
    );
    const labels = {
      copy: article?.getAttribute("data-copy-code-label") || "Copy code",
      copied: article?.getAttribute("data-copied-code-label") || "Copied",
      failed: article?.getAttribute("data-copy-failed-label") || "Copy failed"
    };

    const fallbackCopy = (text) => {
      const textarea = document.createElement("textarea");
      textarea.value = text;
      textarea.setAttribute("readonly", "");
      textarea.style.position = "fixed";
      textarea.style.opacity = "0";
      document.body.append(textarea);
      textarea.select();
      const command = "exec" + "Command";
      const copied = document[command]("copy");
      textarea.remove();
      if (!copied) throw new Error("copy failed");
    };

    const copyText = async (text) => {
      if (navigator.clipboard?.writeText && window.isSecureContext) {
        await navigator.clipboard.writeText(text);
        return;
      }
      fallbackCopy(text);
    };

    if (!(dialog instanceof HTMLDialogElement) || !(dialogImage instanceof HTMLImageElement)) return;

    const openImage = (image) => {
      dialogImage.src = image.currentSrc || image.src;
      dialogImage.alt = image.alt || "";
      dialog.showModal();
    };

    images.forEach((image) => {
      image.classList.add("zoomable-image");
      image.tabIndex = 0;
      image.setAttribute("role", "button");
      image.addEventListener("click", () => openImage(image));
      image.addEventListener("keydown", (event) => {
        if (event.key === "Enter" || event.key === " ") {
          event.preventDefault();
          openImage(image);
        }
      });
    });

    closeButton?.addEventListener("click", () => dialog.close());
    dialog.addEventListener("click", (event) => {
      if (event.target === dialog) dialog.close();
    });

    codeBlocks.forEach((pre) => {
      pre.dataset.copyEnhanced = "true";
      const frame = document.createElement("div");
      const toolbar = document.createElement("div");
      const button = document.createElement("button");

      frame.className = "code-block-frame";
      toolbar.className = "code-block-toolbar";
      button.className = "code-copy-button";
      button.type = "button";
      button.textContent = labels.copy;
      button.setAttribute("aria-label", labels.copy);

      pre.parentNode?.insertBefore(frame, pre);
      toolbar.append(button);
      frame.append(toolbar, pre);

      button.addEventListener("click", async () => {
        const code = pre.querySelector("code")?.innerText ?? pre.innerText;
        button.disabled = true;

        try {
          await copyText(code.trimEnd());
          button.textContent = labels.copied;
          button.classList.add("copied");
        } catch {
          button.textContent = labels.failed;
          button.classList.add("failed");
        } finally {
          window.setTimeout(() => {
            button.disabled = false;
            button.textContent = labels.copy;
            button.classList.remove("copied", "failed");
          }, 1400);
        }
      });
    });
  })();
</script>
