---
import { t, type Locale } from "../lib/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const options = [
  {
    value: "light",
    label: t(locale, "lightTheme"),
    path: "M12 4V2m0 20v-2m8-8h2M2 12h2m13.66-5.66 1.41-1.41M4.93 19.07l1.41-1.41m0-11.32L4.93 4.93m14.14 14.14-1.41-1.41M16 12a4 4 0 1 1-8 0 4 4 0 0 1 8 0Z"
  },
  {
    value: "system",
    label: t(locale, "systemTheme"),
    path: "M5 5.5A2.5 2.5 0 0 1 7.5 3h9A2.5 2.5 0 0 1 19 5.5v7A2.5 2.5 0 0 1 16.5 15h-9A2.5 2.5 0 0 1 5 12.5v-7ZM9 21h6m-3-6v6"
  },
  {
    value: "dark",
    label: t(locale, "darkTheme"),
    path: "M21 14.5A8.5 8.5 0 0 1 9.5 3 7 7 0 1 0 21 14.5Z"
  }
];
---

<div class="theme-toggle" role="group" aria-label={t(locale, "theme")}>
  {
    options.map((option) => (
      <button type="button" data-theme-choice={option.value} aria-label={option.label} title={option.label}>
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d={option.path}></path>
        </svg>
      </button>
    ))
  }
</div>

<script is:inline>
  (() => {
    const key = "blog-theme";
    const media = window.matchMedia("(prefers-color-scheme: dark)");
    const buttons = [...document.querySelectorAll("[data-theme-choice]")];

    const resolveTheme = (preference) => {
      if (preference === "light" || preference === "dark") return preference;
      return media.matches ? "dark" : "light";
    };

    const applyTheme = (preference, animated = true) => {
      const nextPreference = preference || "system";
      const resolved = resolveTheme(nextPreference);
      const canAnimate = animated && !window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (canAnimate) {
        document.documentElement.classList.add("theme-transitioning");
        window.clearTimeout(window.__themeTransitionTimer);
        window.__themeTransitionTimer = window.setTimeout(() => {
          document.documentElement.classList.remove("theme-transitioning");
        }, 320);
      }

      document.documentElement.dataset.theme = resolved;
      document.documentElement.dataset.themePreference = nextPreference;
      buttons.forEach((button) => {
        const active = button.getAttribute("data-theme-choice") === nextPreference;
        button.classList.toggle("active", active);
        button.setAttribute("aria-pressed", String(active));
      });
      window.dispatchEvent(new CustomEvent("blog-theme-change", { detail: { preference: nextPreference, theme: resolved } }));
    };

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        const preference = button.getAttribute("data-theme-choice") || "system";
        localStorage.setItem(key, preference);
        applyTheme(preference);
      });
    });

    media.addEventListener("change", () => {
      if ((localStorage.getItem(key) || "system") === "system") applyTheme("system");
    });

    applyTheme(localStorage.getItem(key) || "system", false);
  })();
</script>
