---
interface Props {
  term: string;
  locale: "zh" | "en";
}

const { term, locale } = Astro.props;
const enabled = import.meta.env.PUBLIC_GISCUS_ENABLED === "true";
const repo = import.meta.env.PUBLIC_GISCUS_REPO;
const repoId = import.meta.env.PUBLIC_GISCUS_REPO_ID;
const category = import.meta.env.PUBLIC_GISCUS_CATEGORY || "General";
const categoryId = import.meta.env.PUBLIC_GISCUS_CATEGORY_ID;
const theme = import.meta.env.PUBLIC_GISCUS_THEME || "preferred_color_scheme";
---

{
  enabled && repo && repoId && categoryId ? (
    <script
      is:inline
      src="https://giscus.app/client.js"
      data-repo={repo}
      data-repo-id={repoId}
      data-category={category}
      data-category-id={categoryId}
      data-mapping="specific"
      data-term={term}
      data-strict="1"
      data-reactions-enabled="1"
      data-emit-metadata="0"
      data-input-position="top"
      data-theme={theme}
      data-lang={locale === "zh" ? "zh-CN" : "en"}
      crossorigin="anonymous"
      async
    />
  ) : (
    <p class="muted"><slot /></p>
  )
}

{
  enabled && (
    <script is:inline>
      window.addEventListener("blog-theme-change", (event) => {
        const frame = document.querySelector("iframe.giscus-frame");
        const theme = event instanceof CustomEvent && event.detail?.theme === "dark" ? "dark" : "light";

        if (frame instanceof HTMLIFrameElement) {
          frame.contentWindow?.postMessage({ giscus: { setConfig: { theme } } }, "https://giscus.app");
        }
      });
    </script>
  )
}
