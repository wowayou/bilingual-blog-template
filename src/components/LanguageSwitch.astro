---
import { localeLabels, locales, type Locale } from "../lib/i18n";

type Alternate = {
  href: string;
  available: boolean;
};

interface Props {
  currentLocale: Locale;
  alternates: Partial<Record<Locale, Alternate>>;
}

const { currentLocale, alternates } = Astro.props;
---

<nav class="language-switch" aria-label="Language">
  {
    locales.map((locale) => {
      const alternate = alternates[locale];
      const isCurrent = locale === currentLocale;

      return alternate?.available ? (
        <a class:list={["language-pill", { active: isCurrent }]} href={alternate.href} aria-current={isCurrent ? "page" : undefined}>
          {localeLabels[locale]}
        </a>
      ) : (
        <span class="language-pill disabled" aria-disabled="true" title="Not translated">
          {localeLabels[locale]}
        </span>
      );
    })
  }
</nav>
