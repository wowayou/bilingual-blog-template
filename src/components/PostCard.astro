---
import type { ContentEntry } from "../lib/content";
import { formatDate } from "../lib/content";
import { type Locale, tagLabel } from "../lib/i18n";

interface Props {
  entry: ContentEntry;
  href: string;
  locale: Locale;
  cta: string;
}

const { entry, href, locale, cta } = Astro.props;
const cover = entry.data.cover;
---

<article class:list={["entry-card", { "has-cover": cover }]}>
  {
    cover && (
      <a class="entry-card-cover" href={href} aria-label={entry.data.title}>
        <img src={cover.src} alt={cover.alt} loading="lazy" style={cover.objectPosition ? `object-position: ${cover.objectPosition}` : undefined} />
      </a>
    )
  }
  <div class="entry-card-body">
    <div class="entry-meta">
      <time datetime={entry.data.pubDate.toISOString()}>{formatDate(entry.data.pubDate, locale)}</time>
      {
        entry.data.tags.length > 0 && (
          <span>{entry.data.tags.map((tag) => tagLabel(tag, locale)).join(" / ")}</span>
        )
      }
    </div>
    <h2><a href={href}>{entry.data.title}</a></h2>
    <p>{entry.data.description}</p>
    <a class="text-link entry-card-cta" href={href}>
      <span>{cta}</span>
      <svg viewBox="0 0 16 16" aria-hidden="true">
        <path d="M3 8h9" />
        <path d="m8 4 4 4-4 4" />
      </svg>
    </a>
  </div>
</article>
